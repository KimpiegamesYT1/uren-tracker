{
  "expo": {
    "name": "uren-tracker",
    "slug": "uren-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-appstore.png",
    "scheme": "urentracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2E546A",
        "foregroundImage": "./assets/images/app-icon-playstore.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.kimpiegames.urentracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon-playstore.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "De app gebruikt de camera om bonfoto's te maken."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c8ea6b17-5921-47a3-9653-adee515c6dce"
      }
    }
  }
}
